REACT_APP_NAME="Quality Install Tool"
REACT_APP_HOMEPAGE="https://www.pnnl.gov/projects/quality-install-tool"

REACT_APP_POUCHDB_DATABASE_NAME="quality-install-tool"

REACT_APP_POUCHDB_MIGRATIONS_DATABASE_NAME="quality-install-tool-migrations"

REACT_APP_GEOLOCATION_MAXIMUM_AGE=0
REACT_APP_GEOLOCATION_TIMEOUT_MILLIS=60000

REACT_APP_JSON_DOCUMENT_CONTENT_TYPE="application/json"
REACT_APP_JSON_DOCUMENT_FILE_EXTENSION=".qit.json"
REACT_APP_PDF_DOCUMENT_FILE_EXTENSION=".qit.pdf"


# default profile used by the app
REACT_APP_PHOTO_PROFILE_DEFAULT=standard

# LOW (fastest upload, lowest quality)
REACT_APP_PHOTO_PREVIEW_MAX_WIDTH_PX=800
REACT_APP_PHOTO_PREVIEW_MAX_HEIGHT_PX=600
REACT_APP_PHOTO_PREVIEW_MAX_SIZE_MB=0.2
REACT_APP_PHOTO_PREVIEW_QUALITY=0.65
REACT_APP_PHOTO_PREVIEW_FORMATS=jpeg

# STANDARD (good quality, reasonable upload size)
REACT_APP_PHOTO_STANDARD_MAX_WIDTH_PX=1600
REACT_APP_PHOTO_STANDARD_MAX_HEIGHT_PX=1200
REACT_APP_PHOTO_STANDARD_MAX_SIZE_MB=0.75
REACT_APP_PHOTO_STANDARD_QUALITY=0.83
REACT_APP_PHOTO_STANDARD_FORMATS=jpeg

# HIGH (best quality, largest file size) 
# these settings are used for the "original" photo that 
# is stored with the project, and for photos included in the PDF report. 
# If the original photo is HEIC, it will be stored as JPEG for
# browser compatibility.
REACT_APP_PHOTO_HIGH_MAX_WIDTH_PX=3072
REACT_APP_PHOTO_HIGH_MAX_HEIGHT_PX=3072
REACT_APP_PHOTO_HIGH_MAX_SIZE_MB=2
REACT_APP_PHOTO_HIGH_QUALITY=0.9
REACT_APP_PHOTO_HIGH_FORMATS=jpeg


REACT_APP_PRINT_TITLE="DOE - Quality Installation Report"
REACT_APP_CONTACT_EMAIL="QItool@pnnl.gov"
